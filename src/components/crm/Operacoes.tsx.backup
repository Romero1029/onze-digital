import { useState, useEffect, useMemo } from 'react';
import { supabase } from '@/integrations/supabase/client';
import { useAuth } from '@/contexts/AuthContext';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Button } from '@/components/ui/button';
import { Progress } from '@/components/ui/progress';
import { toast } from '@/components/ui/use-toast';
import { Plus, Calendar, CalendarDays } from 'lucide-react';

// Componentes extraídos
import { OperacoesHeader } from './operacoes/OperacoesHeader';
import { TarefasView } from './operacoes/TarefasView';
import { CalendarioGeralView } from './operacoes/CalendarioGeralView';
import { CalendarioConteudoView } from './operacoes/CalendarioConteudoView';
import { TarefaModal } from './operacoes/TarefaModal';
import { NovaTarefaModal } from './operacoes/NovaTarefaModal';

// Configuração do localizer para react-big-calendar
const localizer = dateFnsLocalizer({
  format,
  parse,
  startOfWeek,
  getDay,
  locales: {
    'pt-BR': ptBR,
  },
});

// Interfaces simplificadas
interface Tarefa {
  id: string;
  titulo: string;
  descricao?: string;
  prioridade: 'baixa' | 'media' | 'alta' | 'urgente';
  status: 'pendente' | 'em_andamento' | 'concluida' | 'cancelada';
  progresso: number;
  prazo?: string;
  responsavel_id?: string;
  created_at: string;
  updated_at: string;
}

interface Lancamento {
  id: string;
  nome: string;
  data_inicio?: string;
  data_fim?: string;
}

interface NPAEvento {
  id: string;
  nome: string;
  data_inicio?: string;
  data_fim?: string;
}

interface EventoCalendario {
  id: string;
  titulo: string;
  descricao?: string;
  data_inicio: string;
  data_fim?: string;
  cor: string;
}

interface ConteudoCalendario {
  id: string;
  titulo: string;
  plataforma: 'instagram' | 'youtube' | 'tiktok' | 'linkedin';
  data_publicacao: string;
  status: 'rascunho' | 'agendado' | 'publicado' | 'cancelado';
}

interface Usuario {
  id: string;
  nome: string;
  email: string;
}

// Componentes customizados para o calendário
const CustomToolbar = ({ label, onNavigate, onView, view }: any) => {
  const goToBack = () => onNavigate('PREV');
  const goToNext = () => onNavigate('NEXT');
  const goToCurrent = () => onNavigate('TODAY');

  return (
    <div className="flex items-center justify-between p-4 border-b border-border bg-white rounded-t-lg">
      <div className="flex items-center gap-4">
        <h2 className="text-xl font-bold text-foreground">{label}</h2>
        <div className="flex gap-1">
          <Button variant="outline" size="sm" onClick={goToBack} className="h-8 w-8 p-0 rounded-full">
            ‹
          </Button>
          <Button variant="outline" size="sm" onClick={goToCurrent} className="h-8 px-3">
            Hoje
          </Button>
          <Button variant="outline" size="sm" onClick={goToNext} className="h-8 w-8 p-0 rounded-full">
            ›
          </Button>
        </div>
      </div>
      <div className="flex bg-muted rounded-lg p-1">
        <Button
          variant={view === 'month' ? 'default' : 'ghost'}
          size="sm"
          onClick={() => onView('month')}
          className="h-7 px-3 text-xs"
        >
          Mês
        </Button>
        <Button
          variant={view === 'week' ? 'default' : 'ghost'}
          size="sm"
          onClick={() => onView('week')}
          className="h-7 px-3 text-xs"
        >
          Semana
        </Button>
        <Button
          variant={view === 'day' ? 'default' : 'ghost'}
          size="sm"
          onClick={() => onView('day')}
          className="h-7 px-3 text-xs"
        >
          Dia
        </Button>
      </div>
    </div>
  );
};

const CustomEvent = ({ event }: any) => {
  const getEventIcon = (type: string) => {
    switch (type) {
      case 'tarefa': return '📋';
      case 'lancamento': return '🚀';
      case 'npa': return '📊';
      case 'evento': return '📅';
      case 'conteudo': return getPlataformaIcon(event.resource?.plataforma);
      default: return '📅';
    }
  };

  const getPlataformaIcon = (plataforma?: string) => {
    switch (plataforma) {
      case 'instagram': return '📷';
      case 'youtube': return '▶️';
      case 'tiktok': return '♪';
      case 'linkedin': return '💼';
      default: return '📱';
    }
  };

  return (
    <div
      className="text-xs font-medium text-white px-2 py-1 rounded-md truncate flex items-center gap-1"
      style={{ backgroundColor: event.backgroundColor }}
    >
      <span>{getEventIcon(event.resource?.type || 'evento')}</span>
      <span className="truncate">{event.title}</span>
    </div>
  );
};

const CustomDateCellWrapper = ({ children, value }: any) => {
  const isToday = isSameMonth(value, new Date()) && value.getDate() === new Date().getDate() && value.getMonth() === new Date().getMonth();

  return (
    <div className={`relative min-h-[100px] p-1 hover:bg-gray-50 transition-colors ${isToday ? 'bg-red-50' : ''}`}>
      <div className={`absolute top-1 right-1 w-6 h-6 flex items-center justify-center text-xs font-medium rounded-full ${
        isToday ? 'bg-red-600 text-white' : 'text-gray-600'
      }`}>
        {value.getDate()}
      </div>
      <div className="pt-8">
        {children}
      </div>
    </div>
  );
};

const CustomWeekHeader = ({ date }: any) => {
  const dayNames = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];
  return (
    <div className="text-xs font-medium text-gray-500 uppercase tracking-wide py-2">
      {dayNames[date.getDay()]}
    </div>
  );
};

export function Operacoes() {
  const { user, users } = useAuth();
  const [activeTab, setActiveTab] = useState<'tarefas' | 'calendario_geral' | 'calendario_conteudo'>('tarefas');
  const [viewMode, setViewMode] = useState<ViewMode>('list');
  const [groupBy, setGroupBy] = useState<GroupBy>('status');

  // Estados para Tarefas
  const [tarefas, setTarefas] = useState<Tarefa[]>([]);
  const [tarefasEtapas, setTarefasEtapas] = useState<TarefaEtapa[]>([]);
  const [tarefasChecklists, setTarefasChecklists] = useState<TarefaChecklist[]>([]);
  const [tarefasComentarios, setTarefasComentarios] = useState<TarefaComentario[]>([]);

  // Estados para Calendários
  const [eventosCalendario, setEventosCalendario] = useState<EventoCalendario[]>([]);
  const [conteudoCalendario, setConteudoCalendario] = useState<ConteudoCalendario[]>([]);
  const [lancamentos, setLancamentos] = useState<any[]>([]);
  const [npaEventos, setNpaEventos] = useState<any[]>([]);

  // Estados de UI
  const [loading, setLoading] = useState(true);
  const [searchText, setSearchText] = useState('');
  const [filterStatus, setFilterStatus] = useState<string>('todos');
  const [filterPrioridade, setFilterPrioridade] = useState<string>('todos');
  const [filterResponsavel, setFilterResponsavel] = useState<string>('todos');
  const [filterTipo, setFilterTipo] = useState<string>('todos');
  const [minhasTarefas, setMinhasTarefas] = useState(false);

  // Estados para Calendários
  const [calendarView, setCalendarView] = useState<View>(Views.MONTH);
  const [selectedDate, setSelectedDate] = useState(new Date());
  const [plataformaFilter, setPlataformaFilter] = useState<string>('todos');

  // Estados para edição inline na tabela
  const [editingCell, setEditingCell] = useState<{ tarefaId: string; field: string } | null>(null);
  const [editValues, setEditValues] = useState<Record<string, any>>({});

  // Modais
  const [showCreateTarefa, setShowCreateTarefa] = useState(false);
  const [showTarefaDetail, setShowTarefaDetail] = useState(false);
  const [showCreateEvento, setShowCreateEvento] = useState(false);
  const [showCreateConteudo, setShowCreateConteudo] = useState(false);
  const [showDeleteConfirm, setShowDeleteConfirm] = useState(false);

  // Dados selecionados
  const [selectedTarefa, setSelectedTarefa] = useState<Tarefa | null>(null);
  const [itemToDelete, setItemToDelete] = useState<{ type: string; id: string; name: string } | null>(null);

  // Formulários
  const [tarefaForm, setTarefaForm] = useState({
    titulo: '',
    descricao: '',
    tipo: 'unitaria' as 'unitaria' | 'sequencial',
    prioridade: 'media' as 'baixa' | 'media' | 'alta' | 'urgente',
    responsaveis: [] as string[],
    data_inicio: '',
    prazo: '',
    tags: [] as string[]
  });

  const [eventoForm, setEventoForm] = useState({
    titulo: '',
    descricao: '',
    data_inicio: '',
    data_fim: '',
    cor: '#3b82f6'
  });

  const [conteudoForm, setConteudoForm] = useState({
    titulo: '',
    plataforma: 'instagram' as 'instagram' | 'youtube' | 'tiktok' | 'linkedin',
    formato: 'feed' as 'reels' | 'feed' | 'stories' | 'carrossel' | 'video' | 'short',
    responsavel: '',
    status: 'ideia' as 'ideia' | 'roteiro' | 'gravando' | 'editando' | 'agendado' | 'publicado',
    data_publicacao: '',
    legenda: '',
    link: '',
    observacoes: ''
  });

  // Carregar dados
  useEffect(() => {
    loadData();
  }, []);

  const loadData = async () => {
    setLoading(true);
    try {
      // Carregar tarefas
      try {
        const tarefasRes = await supabase.from('tarefas').select('*').order('created_at', { ascending: false });
        if (tarefasRes.data) setTarefas(tarefasRes.data);
      } catch (error) {
        console.error('Erro ao carregar tarefas:', error);
      }

      // Carregar etapas
      try {
        const etapasRes = await supabase.from('tarefas_etapas').select('*');
        if (etapasRes.data) setTarefasEtapas(etapasRes.data);
      } catch (error) {
        console.error('Erro ao carregar etapas:', error);
      }

      // Carregar checklists
      try {
        const checklistsRes = await supabase.from('tarefas_checklists').select('*');
        if (checklistsRes.data) setTarefasChecklists(checklistsRes.data);
      } catch (error) {
        console.error('Erro ao carregar checklists:', error);
      }

      // Carregar comentários
      try {
        const comentariosRes = await supabase.from('tarefas_comentarios').select('*');
        if (comentariosRes.data) setTarefasComentarios(comentariosRes.data);
      } catch (error) {
        console.error('Erro ao carregar comentários:', error);
      }

      // Carregar eventos do calendário
      try {
        const eventosRes = await supabase.from('eventos_calendario').select('*');
        if (eventosRes.data) setEventosCalendario(eventosRes.data);
      } catch (error) {
        console.error('Erro ao carregar eventos do calendário:', error);
      }

      // Carregar conteúdo do calendário
      try {
        const conteudoRes = await supabase.from('conteudo_calendario').select('*');
        if (conteudoRes.data) setConteudoCalendario(conteudoRes.data);
      } catch (error) {
        console.error('Erro ao carregar conteúdo do calendário:', error);
      }

      // Carregar lançamentos (remover se tabela não existir)
      try {
        const lancamentosRes = await supabase.from('lancamentos').select('*').limit(50);
        if (lancamentosRes.data) setLancamentos(lancamentosRes.data);
      } catch (error) {
        console.warn('Erro ao buscar tabela lancamentos:', error);
        setLancamentos([]);
      }

      // Carregar eventos NPA (remover se tabela não existir)
      try {
        const npaRes = await supabase.from('npa_eventos').select('*').limit(50);
        if (npaRes.data) setNpaEventos(npaRes.data);
      } catch (error) {
        console.warn('Erro ao buscar tabela npa_eventos:', error);
        setNpaEventos([]);
      }
    } catch (error) {
      console.error('Erro geral ao carregar dados:', error);
      toast({
        variant: 'destructive',
        title: 'Erro',
        description: 'Falha ao carregar dados das operações'
      });
    } finally {
      setLoading(false);
    }
  };

  // Filtros e cálculos
  const filteredTarefas = useMemo(() => {
    return tarefas.filter(tarefa => {
      const matchesSearch = tarefa.titulo.toLowerCase().includes(searchText.toLowerCase()) ||
        (tarefa.descricao && tarefa.descricao.toLowerCase().includes(searchText.toLowerCase()));
      const matchesStatus = filterStatus === 'todos' || tarefa.status === filterStatus;
      const matchesPrioridade = filterPrioridade === 'todos' || tarefa.prioridade === filterPrioridade;
      const matchesResponsavel = filterResponsavel === 'todos' ||
        (filterResponsavel === 'minhas' ? (tarefa.responsaveis ?? []).includes(user?.id || '') : (tarefa.responsaveis ?? []).includes(filterResponsavel));
      const matchesTipo = filterTipo === 'todos' || tarefa.tipo === filterTipo;
      const matchesMinhasTarefas = !minhasTarefas || (tarefa.responsaveis ?? []).includes(user?.id || '');

      return matchesSearch && matchesStatus && matchesPrioridade && matchesResponsavel && matchesTipo && matchesMinhasTarefas;
    });
  }, [tarefas, searchText, filterStatus, filterPrioridade, filterResponsavel, filterTipo, minhasTarefas, user?.id]);

  const completionRate = useMemo(() => {
    if (filteredTarefas.length === 0) return 0;
    const completed = filteredTarefas.filter(t => t.status === 'concluido').length;
    return Math.round((completed / filteredTarefas.length) * 100);
  }, [filteredTarefas]);

  // Funções de cores e ícones
  const getPriorityColor = (prioridade: string) => {
    switch (prioridade) {
      case 'urgente': return 'bg-red-100 text-red-800 border-red-200';
      case 'alta': return 'bg-orange-100 text-orange-800 border-orange-200';
      case 'media': return 'bg-yellow-100 text-yellow-800 border-yellow-200';
      case 'baixa': return 'bg-green-100 text-green-800 border-green-200';
      default: return 'bg-gray-100 text-gray-800 border-gray-200';
    }
  };

  const getPriorityHexColor = (prioridade: string) => {
    switch (prioridade) {
      case 'urgente': return '#dc2626';
      case 'alta': return '#ea580c';
      case 'media': return '#f59e0b';
      case 'baixa': return '#16a34a';
      default: return '#6b7280';
    }
  };
  };

  const getPlataformaIcon = (plataforma: string) => {
    switch (plataforma) {
      case 'instagram': return <Instagram className="h-4 w-4" />;
      case 'youtube': return <Youtube className="h-4 w-4" />;
      case 'tiktok': return <Music className="h-4 w-4" />;
      case 'linkedin': return <Linkedin className="h-4 w-4" />;
      default: return <Target className="h-4 w-4" />;
    }
  };

  const getPlataformaColor = (plataforma: string) => {
    switch (plataforma) {
      case 'instagram': return 'bg-pink-100 text-pink-800';
      case 'youtube': return 'bg-red-100 text-red-800';
      case 'tiktok': return 'bg-black text-white';
      case 'linkedin': return 'bg-blue-100 text-blue-800';
      default: return 'bg-gray-100 text-gray-800';
    }
  };

  // Funções de ação
  const createTarefa = async () => {
    if (!tarefaForm.titulo.trim()) return;

    try {
      const { data, error } = await supabase
        .from('tarefas')
        .insert({
          titulo: tarefaForm.titulo,
          descricao: tarefaForm.descricao || null,
          tipo: tarefaForm.tipo,
          status: 'a_fazer',
          prioridade: tarefaForm.prioridade,
          responsaveis: tarefaForm.responsaveis,
          data_inicio: tarefaForm.data_inicio || null,
          prazo: tarefaForm.prazo || null,
          tags: tarefaForm.tags,
          created_by: user?.id
        })
        .select()
        .single();

      if (error) throw error;

      toast({ title: 'Tarefa criada!', description: 'Tarefa criada com sucesso.' });
      setShowCreateTarefa(false);
      setTarefaForm({
        titulo: '',
        descricao: '',
        tipo: 'unitaria',
        prioridade: 'media',
        responsaveis: [],
        data_inicio: '',
        prazo: '',
        tags: []
      });
      loadData();
    } catch (error: any) {
      toast({
        variant: 'destructive',
        title: 'Erro',
        description: error.message || 'Erro ao criar tarefa'
      });
    }
  };

  const updateTarefaStatus = async (tarefaId: string, newStatus: string) => {
    try {
      const { error } = await supabase
        .from('tarefas')
        .update({ status: newStatus, updated_at: new Date().toISOString() })
        .eq('id', tarefaId);

      if (error) throw error;

      // Se for tarefa sequencial e concluindo uma etapa, desbloquear próxima
      const tarefa = tarefas.find(t => t.id === tarefaId);
      if (tarefa?.tipo === 'sequencial' && newStatus === 'concluido') {
        // Lógica para desbloquear próxima etapa
      }

      loadData();
    } catch (error: any) {
      toast({
        variant: 'destructive',
        title: 'Erro',
        description: error.message || 'Erro ao atualizar status'
      });
    }
  };

  const deleteTarefa = async () => {
    if (!itemToDelete) return;

    try {
      const { error } = await supabase
        .from('tarefas')
        .delete()
        .eq('id', itemToDelete.id);

      if (error) throw error;

      toast({ title: 'Tarefa excluída!', description: 'Tarefa removida com sucesso.' });
      setShowDeleteConfirm(false);
      setItemToDelete(null);
      loadData();
    } catch (error: any) {
      toast({
        variant: 'destructive',
        title: 'Erro',
        description: error.message || 'Erro ao excluir tarefa'
      });
    }
  };

  const openTarefaDetail = (tarefa: Tarefa) => {
    setSelectedTarefa(tarefa);
    setShowTarefaDetail(true);
  };

  const confirmDelete = (type: string, id: string, name: string) => {
    setItemToDelete({ type, id, name });
    setShowDeleteConfirm(true);
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center h-full">
        <div className="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
      </div>
    );
  }

  return (
    <div className="h-full flex flex-col bg-white">
      {/* Header */}
      <div className="p-4 lg:p-6 border-b border-border">
        <div className="flex flex-col gap-4">
          <div className="flex items-center justify-between">
            <div>
              <h1 className="text-2xl font-bold text-foreground">Operações</h1>
              <p className="text-sm text-muted-foreground mt-0.5">Centro de controle de produtividade</p>
            </div>
            <div className="flex gap-2">
              {activeTab === 'tarefas' && (
                <Button
                  onClick={() => setShowCreateTarefa(true)}
                  className="bg-red-600 hover:bg-red-700 text-white"
                >
                  <Plus className="h-4 w-4 mr-2" />Nova Tarefa
                </Button>
              )}
              {activeTab === 'calendario_geral' && (
                <Button
                  onClick={() => setShowCreateEvento(true)}
                  className="bg-primary hover:bg-primary/90"
                >
                  <Plus className="h-4 w-4 mr-2" />Novo Evento
                </Button>
              )}
              {activeTab === 'calendario_conteudo' && (
                <Button
                  onClick={() => setShowCreateConteudo(true)}
                  className="bg-primary hover:bg-primary/90"
                >
                  <Plus className="h-4 w-4 mr-2" />Novo Conteúdo
                </Button>
              )}
            </div>
          </div>
        </div>
      </div>

      {/* Tabs */}
      <Tabs value={activeTab} onValueChange={(value: any) => setActiveTab(value)} className="flex-1 flex flex-col">
        <div className="px-4 lg:px-6 pt-4 border-b border-border">
          <TabsList className="grid w-full max-w-md grid-cols-3">
            <TabsTrigger value="tarefas">✅ Tarefas</TabsTrigger>
            <TabsTrigger value="calendario_geral">📅 Calendário Geral</TabsTrigger>
            <TabsTrigger value="calendario_conteudo">🗓️ Calendário de Conteúdo</TabsTrigger>
          </TabsList>
        </div>

        {/* Sub-aba Tarefas */}
        <TabsContent value="tarefas" className="flex-1 flex flex-col">
          {/* Barra superior das tarefas */}
          <div className="p-4 lg:p-6 border-b border-border">
            <div className="flex flex-col gap-4">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-4">
                  <h2 className="text-xl font-bold">Tarefas</h2>
                  <div className="flex items-center gap-2">
                    <span className="text-sm text-muted-foreground">
                      {filteredTarefas.length} tarefas • {completionRate}% completo
                    </span>
                    <Progress value={completionRate} className="w-24 h-2" />
                  </div>
                </div>
              </div>

              {/* Controles de visualização */}
              <div className="flex items-center gap-2">
                <div className="flex bg-muted rounded-lg p-1">
                  <Button
                    variant={viewMode === 'list' ? 'default' : 'ghost'}
                    size="sm"
                    onClick={() => setViewMode('list')}
                    className="h-8 px-3"
                  >
                    <List className="h-4 w-4 mr-1" />
                    Lista
                  </Button>
                  <Button
                    variant={viewMode === 'kanban' ? 'default' : 'ghost'}
                    size="sm"
                    onClick={() => setViewMode('kanban')}
                    className="h-8 px-3"
                  >
                    <Kanban className="h-4 w-4 mr-1" />
                    Kanban
                  </Button>
                  <Button
                    variant={viewMode === 'calendar' ? 'default' : 'ghost'}
                    size="sm"
                    onClick={() => setViewMode('calendar')}
                    className="h-8 px-3"
                  >
                    <Calendar className="h-4 w-4 mr-1" />
                    Calendário
                  </Button>
                  <Button
                    variant={viewMode === 'table' ? 'default' : 'ghost'}
                    size="sm"
                    onClick={() => setViewMode('table')}
                    className="h-8 px-3"
                  >
                    <Table className="h-4 w-4 mr-1" />
                    Tabela
                  </Button>
                </div>
              </div>

              {/* Filtros */}
              <div className="flex flex-col lg:flex-row gap-2">
                <div className="flex items-center gap-2">
                  <Button
                    variant={minhasTarefas ? 'default' : 'outline'}
                    size="sm"
                    onClick={() => setMinhasTarefas(!minhasTarefas)}
                    className="h-8 px-3"
                  >
                    <UserCheck className="h-4 w-4 mr-1" />
                    Minhas Tarefas
                  </Button>
                </div>
                <div className="flex-1 flex items-center gap-2 px-3 py-2 border border-border rounded bg-muted/30">
                  <Search className="h-4 w-4 text-muted-foreground" />
                  <input
                    type="text"
                    placeholder="Buscar tarefas..."
                    value={searchText}
                    onChange={(e) => setSearchText(e.target.value)}
                    className="flex-1 bg-transparent text-sm placeholder-muted-foreground focus:outline-none"
                  />
                </div>
                <div className="flex gap-2">
                  <Select value={filterStatus} onValueChange={setFilterStatus}>
                    <SelectTrigger className="w-[130px]" size="sm">
                      <SelectValue placeholder="Status" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="todos">Todos</SelectItem>
                      <SelectItem value="a_fazer">A Fazer</SelectItem>
                      <SelectItem value="em_andamento">Em Andamento</SelectItem>
                      <SelectItem value="em_revisao">Em Revisão</SelectItem>
                      <SelectItem value="concluido">Concluído</SelectItem>
                      <SelectItem value="bloqueado">Bloqueado</SelectItem>
                    </SelectContent>
                  </Select>
                  <Select value={filterPrioridade} onValueChange={setFilterPrioridade}>
                    <SelectTrigger className="w-[120px]" size="sm">
                      <SelectValue placeholder="Prioridade" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="todos">Todas</SelectItem>
                      <SelectItem value="urgente">🔴 Urgente</SelectItem>
                      <SelectItem value="alta">🟠 Alta</SelectItem>
                      <SelectItem value="media">🟡 Média</SelectItem>
                      <SelectItem value="baixa">🟢 Baixa</SelectItem>
                    </SelectContent>
                  </Select>
                  <Select value={filterTipo} onValueChange={setFilterTipo}>
                    <SelectTrigger className="w-[120px]" size="sm">
                      <SelectValue placeholder="Tipo" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="todos">Todos</SelectItem>
                      <SelectItem value="unitaria">Unitária</SelectItem>
                      <SelectItem value="sequencial">Sequencial</SelectItem>
                    </SelectContent>
                  </Select>
                  <Select value={filterResponsavel} onValueChange={setFilterResponsavel}>
                    <SelectTrigger className="w-[140px]" size="sm">
                      <SelectValue placeholder="Responsável" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="todos">Todos</SelectItem>
                      <SelectItem value="minhas">Minhas tarefas</SelectItem>
                      {users.filter(u => u.ativo).map(user => (
                        <SelectItem key={user.id} value={user.id}>
                          {user.nome}
                        </SelectItem>
                      ))}
                    </SelectContent>
                  </Select>
                </div>
              </div>

              {/* Agrupar por */}
              <div className="flex items-center gap-2">
                <span className="text-sm text-muted-foreground">Agrupar por:</span>
                <div className="flex gap-1">
                  {(['status', 'prioridade', 'responsavel', 'nenhum'] as GroupBy[]).map(option => (
                    <Button
                      key={option}
                      variant={groupBy === option ? 'default' : 'outline'}
                      size="sm"
                      onClick={() => setGroupBy(option)}
                      className="h-7 px-3 text-xs capitalize"
                    >
                      {option}
                    </Button>
                  ))}
                </div>
              </div>
            </div>
          </div>

          {/* Conteúdo das tarefas */}
          <div className="flex-1 overflow-y-auto p-4 lg:p-6">
            {viewMode === 'list' && <TarefasListView />}
            {viewMode === 'kanban' && <TarefasKanbanView />}
            {viewMode === 'calendar' && <TarefasCalendarView />}
            {viewMode === 'table' && <TarefasTableView />}
          </div>
        </TabsContent>

        {/* Sub-aba Calendário Geral */}
        <TabsContent value="calendario_geral" className="flex-1">
          <CalendarioGeralView />
        </TabsContent>

        {/* Sub-aba Calendário de Conteúdo */}
        <TabsContent value="calendario_conteudo" className="flex-1">
          <CalendarioConteudoView />
        </TabsContent>
      </Tabs>

      {/* Modais */}
      <ModalCreateTarefa />
      <ModalTarefaDetail />
      <ModalCreateEvento />
      <ModalCreateConteudo />
      <ModalDeleteConfirm />
    </div>
  );

  // Componentes auxiliares
  function TarefasListView() {
    if (loading) {
      return (
        <div className="space-y-4">
          {[...Array(3)].map((_, i) => (
            <div key={i} className="space-y-2">
              <div className="h-6 bg-muted animate-pulse rounded w-32"></div>
              {[...Array(2)].map((_, j) => (
                <Card key={j} className="p-4">
                  <div className="space-y-2">
                    <div className="h-4 bg-muted animate-pulse rounded w-3/4"></div>
                    <div className="h-3 bg-muted animate-pulse rounded w-1/2"></div>
                    <div className="flex gap-2">
                      <div className="h-5 bg-muted animate-pulse rounded w-16"></div>
                      <div className="h-5 bg-muted animate-pulse rounded w-16"></div>
                    </div>
                  </div>
                </Card>
              ))}
            </div>
          ))}
        </div>
      );
    }

    const groupedTasks = useMemo(() => {
      if (groupBy === 'nenhum') return { 'Todas': filteredTarefas };

      const groups: Record<string, Tarefa[]> = {};
      filteredTarefas.forEach(task => {
        const key = groupBy === 'status' ? task.status :
                   groupBy === 'prioridade' ? task.prioridade :
                   groupBy === 'responsavel' ? ((task.responsaveis ?? [])[0] || 'Sem responsável') :
                   'Todas';
        if (!groups[key]) groups[key] = [];
        groups[key].push(task);
      });
      return groups;
    }, [filteredTarefas, groupBy]);

    return (
      <div className="space-y-4">
        {Object.entries(groupedTasks).map(([groupName, tasks]) => (
          <div key={groupName}>
            <div className="flex items-center gap-2 mb-3">
              <h3 className="font-medium text-foreground capitalize">{groupName}</h3>
              <Badge variant="secondary">{tasks.length}</Badge>
            </div>
            <div className="space-y-2">
              {tasks.map(task => (
                <TarefaCard key={task.id} tarefa={task} />
              ))}
            </div>
          </div>
        ))}
      </div>
    );
  }

  function TarefasKanbanView() {
    const columns = ['a_fazer', 'em_andamento', 'em_revisao', 'concluido', 'bloqueado'];

    return (
      <div className="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4 h-full">
        {columns.map(column => (
          <div key={column} className="flex flex-col">
            <div className="p-3 bg-muted/50 rounded-t-lg border border-border">
              <h3 className="font-medium text-sm capitalize">
                {column.replace('_', ' ')}
              </h3>
              <Badge variant="secondary" className="mt-1">
                {filteredTarefas.filter(t => t.status === column).length}
              </Badge>
            </div>
            <div className="flex-1 p-2 space-y-2 bg-muted/20 rounded-b-lg border-x border-b border-border min-h-[400px]">
              {filteredTarefas
                .filter(t => t.status === column)
                .map(task => (
                  <TarefaKanbanCard key={task.id} tarefa={task} />
                ))}
            </div>
          </div>
        ))}
      </div>
    );
  }

  function TarefasCalendarView() {
    const calendarEvents = useMemo(() => {
      return filteredTarefas
        .filter(tarefa => tarefa.prazo)
        .map(tarefa => ({
          id: tarefa.id,
          title: tarefa.titulo,
          start: parseISO(tarefa.prazo!),
          end: parseISO(tarefa.prazo!),
          resource: { ...tarefa, type: 'tarefa' },
          backgroundColor: '#DC2626' // Vermelho para tarefas
        }));
    }, [filteredTarefas]);

    const handleEventClick = (event: any) => {
      openTarefaDetail(event.resource);
    };

    return (
      <div className="bg-white rounded-lg shadow-sm border border-border overflow-hidden">
        <BigCalendar
          localizer={localizer}
          events={calendarEvents}
          startAccessor="start"
          endAccessor="end"
          style={{ height: '600px' }}
          views={[Views.MONTH, Views.WEEK, Views.DAY]}
          defaultView={Views.MONTH}
          onSelectEvent={handleEventClick}
          messages={{
            today: 'Hoje',
            previous: '‹',
            next: '›',
            month: 'Mês',
            week: 'Semana',
            day: 'Dia',
            agenda: 'Agenda',
            date: 'Data',
            time: 'Hora',
            event: 'Evento',
            noEventsInRange: 'Nenhum evento neste período',
            showMore: (total) => `+${total} mais`
          }}
          culture="pt-BR"
          components={{
            toolbar: CustomToolbar,
            event: CustomEvent,
            dateCellWrapper: CustomDateCellWrapper,
            header: CustomWeekHeader
          }}
          className="custom-calendar"
        />
      </div>
    );
  }

  function TarefasTableView() {
    const [sortField, setSortField] = useState<string>('titulo');
    const [sortDirection, setSortDirection] = useState<'asc' | 'desc'>('asc');

    const sortedTarefas = useMemo(() => {
      return [...filteredTarefas].sort((a, b) => {
        let aVal: any = a[sortField as keyof Tarefa];
        let bVal: any = b[sortField as keyof Tarefa];

        if (sortField === 'prazo' && aVal && bVal) {
          aVal = new Date(aVal).getTime();
          bVal = new Date(bVal).getTime();
        }

        if (aVal < bVal) return sortDirection === 'asc' ? -1 : 1;
        if (aVal > bVal) return sortDirection === 'asc' ? 1 : -1;
        return 0;
      });
    }, [filteredTarefas, sortField, sortDirection]);

    const handleSort = (field: string) => {
      if (sortField === field) {
        setSortDirection(sortDirection === 'asc' ? 'desc' : 'asc');
      } else {
        setSortField(field);
        setSortDirection('asc');
      }
    };

    const handleCellEdit = (tarefaId: string, field: string, value: any) => {
      setEditValues(prev => ({ ...prev, [`${tarefaId}-${field}`]: value }));
    };

    const handleCellSave = async (tarefaId: string, field: string) => {
      const value = editValues[`${tarefaId}-${field}`];
      if (value !== undefined) {
        try {
          await supabase.from('tarefas').update({ [field]: value }).eq('id', tarefaId);
          setEditValues(prev => {
            const newValues = { ...prev };
            delete newValues[`${tarefaId}-${field}`];
            return newValues;
          });
          // Recarregar dados
          loadData();
          toast({ title: 'Sucesso', description: 'Tarefa atualizada com sucesso' });
        } catch (error) {
          console.error('Erro ao atualizar tarefa:', error);
          toast({ variant: 'destructive', title: 'Erro', description: 'Falha ao atualizar tarefa' });
        }
      }
      setEditingCell(null);
    };

    const handleNewTarefa = () => {
      setShowCreateTarefa(true);
    };

    return (
      <div className="border border-border rounded-lg overflow-hidden">
        <div className="overflow-x-auto">
          <table className="w-full">
            <thead className="bg-muted/50">
              <tr>
                <th className="px-4 py-3 text-left">
                  <Button variant="ghost" size="sm" onClick={() => handleSort('titulo')} className="h-auto p-0 font-medium">
                    Título {sortField === 'titulo' && (sortDirection === 'asc' ? '↑' : '↓')}
                  </Button>
                </th>
                <th className="px-4 py-3 text-left">
                  <Button variant="ghost" size="sm" onClick={() => handleSort('tipo')} className="h-auto p-0 font-medium">
                    Tipo {sortField === 'tipo' && (sortDirection === 'asc' ? '↑' : '↓')}
                  </Button>
                </th>
                <th className="px-4 py-3 text-left">
                  <Button variant="ghost" size="sm" onClick={() => handleSort('status')} className="h-auto p-0 font-medium">
                    Status {sortField === 'status' && (sortDirection === 'asc' ? '↑' : '↓')}
                  </Button>
                </th>
                <th className="px-4 py-3 text-left">
                  <Button variant="ghost" size="sm" onClick={() => handleSort('prioridade')} className="h-auto p-0 font-medium">
                    Prioridade {sortField === 'prioridade' && (sortDirection === 'asc' ? '↑' : '↓')}
                  </Button>
                </th>
                <th className="px-4 py-3 text-left">Responsável</th>
                <th className="px-4 py-3 text-left">
                  <Button variant="ghost" size="sm" onClick={() => handleSort('prazo')} className="h-auto p-0 font-medium">
                    Prazo {sortField === 'prazo' && (sortDirection === 'asc' ? '↑' : '↓')}
                  </Button>
                </th>
                <th className="px-4 py-3 text-center">Ações</th>
              </tr>
            </thead>
            <tbody>
              {sortedTarefas.map(tarefa => (
                <tr key={tarefa.id} className="border-t border-border hover:bg-muted/30">
                  <td className="px-4 py-3">
                    {editingCell?.tarefaId === tarefa.id && editingCell.field === 'titulo' ? (
                      <div className="flex items-center gap-2">
                        <Input
                          value={editValues[`${tarefa.id}-titulo`] ?? tarefa.titulo}
                          onChange={(e) => handleCellEdit(tarefa.id, 'titulo', e.target.value)}
                          className="h-8"
                        />
                        <Button size="sm" onClick={() => handleCellSave(tarefa.id, 'titulo')} className="h-8 w-8 p-0">
                          <Save className="h-3 w-3" />
                        </Button>
                        <Button size="sm" variant="outline" onClick={() => setEditingCell(null)} className="h-8 w-8 p-0">
                          <X className="h-3 w-3" />
                        </Button>
                      </div>
                    ) : (
                      <div onClick={() => setEditingCell({ tarefaId: tarefa.id, field: 'titulo' })} className="cursor-pointer">
                        {tarefa.titulo}
                      </div>
                    )}
                  </td>
                  <td className="px-4 py-3">
                    <Badge variant="outline">{tarefa.tipo === 'sequencial' ? 'Sequencial' : 'Unitária'}</Badge>
                  </td>
                  <td className="px-4 py-3">
                    {editingCell?.tarefaId === tarefa.id && editingCell.field === 'status' ? (
                      <Select
                        value={editValues[`${tarefa.id}-status`] ?? tarefa.status}
                        onValueChange={(value) => handleCellEdit(tarefa.id, 'status', value)}
                      >
                        <SelectTrigger className="h-8 w-32">
                          <SelectValue />
                        </SelectTrigger>
                        <SelectContent>
                          <SelectItem value="a_fazer">A Fazer</SelectItem>
                          <SelectItem value="em_andamento">Em Andamento</SelectItem>
                          <SelectItem value="em_revisao">Em Revisão</SelectItem>
                          <SelectItem value="concluido">Concluído</SelectItem>
                          <SelectItem value="bloqueado">Bloqueado</SelectItem>
                        </SelectContent>
                      </Select>
                    ) : (
                      <div onClick={() => setEditingCell({ tarefaId: tarefa.id, field: 'status' })} className="cursor-pointer">
                        <Badge className={getStatusColor(tarefa.status)}>
                          {tarefa.status.replace('_', ' ')}
                        </Badge>
                      </div>
                    )}
                  </td>
                  <td className="px-4 py-3">
                    {editingCell?.tarefaId === tarefa.id && editingCell.field === 'prioridade' ? (
                      <Select
                        value={editValues[`${tarefa.id}-prioridade`] ?? tarefa.prioridade}
                        onValueChange={(value) => handleCellEdit(tarefa.id, 'prioridade', value)}
                      >
                        <SelectTrigger className="h-8 w-32">
                          <SelectValue />
                        </SelectTrigger>
                        <SelectContent>
                          <SelectItem value="baixa">Baixa</SelectItem>
                          <SelectItem value="media">Média</SelectItem>
                          <SelectItem value="alta">Alta</SelectItem>
                          <SelectItem value="urgente">Urgente</SelectItem>
                        </SelectContent>
                      </Select>
                    ) : (
                      <div onClick={() => setEditingCell({ tarefaId: tarefa.id, field: 'prioridade' })} className="cursor-pointer">
                        <Badge className={getPriorityColor(tarefa.prioridade)}>
                          {tarefa.prioridade}
                        </Badge>
                      </div>
                    )}
                  </td>
                  <td className="px-4 py-3">
                    <div className="flex flex-wrap gap-1">
                      {(tarefa.responsaveis ?? []).slice(0, 2).map(respId => {
                        const user = users.find(u => u.id === respId);
                        return user ? (
                          <Badge key={respId} variant="secondary" className="text-xs">
                            {user.nome.split(' ')[0]}
                          </Badge>
                        ) : null;
                      })}
                    </div>
                  </td>
                  <td className="px-4 py-3">
                    {editingCell?.tarefaId === tarefa.id && editingCell.field === 'prazo' ? (
                      <Input
                        type="date"
                        value={(editValues[`${tarefa.id}-prazo`] ?? tarefa.prazo?.split('T')[0]) || ''}
                        onChange={(e) => handleCellEdit(tarefa.id, 'prazo', e.target.value)}
                        className="h-8 w-32"
                      />
                    ) : (
                      <div onClick={() => setEditingCell({ tarefaId: tarefa.id, field: 'prazo' })} className="cursor-pointer">
                        {tarefa.prazo ? format(parseISO(tarefa.prazo), 'dd/MM/yyyy') : '-'}
                      </div>
                    )}
                  </td>
                  <td className="px-4 py-3 text-center">
                    <div className="flex justify-center gap-1">
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => openTarefaDetail(tarefa)}
                        className="h-8 w-8 p-0"
                      >
                        <Eye className="h-3 w-3" />
                      </Button>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => confirmDelete('tarefa', tarefa.id, tarefa.titulo)}
                        className="h-8 w-8 p-0 text-destructive hover:text-destructive"
                      >
                        <Trash2 className="h-3 w-3" />
                      </Button>
                    </div>
                  </td>
                </tr>
              ))}
              {/* Linha para nova tarefa */}
              <tr className="border-t border-border bg-muted/20">
                <td colSpan={7} className="px-4 py-3">
                  <Button variant="outline" size="sm" onClick={handleNewTarefa} className="w-full">
                    <Plus className="h-4 w-4 mr-2" />
                    Nova Tarefa
                  </Button>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    );
  }

  function CalendarioGeralView() {
    const [showCreateEvento, setShowCreateEvento] = useState(false);
    const [eventoForm, setEventoForm] = useState({
      titulo: '',
      descricao: '',
      data_inicio: '',
      data_fim: '',
      cor: '#3b82f6'
    });

    const geralEvents = useMemo(() => {
      const events: any[] = [];

      // Tarefas com prazo
      tarefas
        .filter(t => t.prazo)
        .forEach(tarefa => {
          events.push({
            id: `tarefa-${tarefa.id}`,
            title: tarefa.titulo,
            start: parseISO(tarefa.prazo!),
            end: parseISO(tarefa.prazo!),
            backgroundColor: getPriorityHexColor(tarefa.prioridade),
            resource: { type: 'tarefa', data: tarefa }
          });
        });

      // Lançamentos
      lancamentos.forEach(lancamento => {
        if (lancamento.data_inicio) {
          events.push({
            id: `lancamento-${lancamento.id}`,
            title: lancamento.nome,
            start: parseISO(lancamento.data_inicio),
            end: lancamento.data_fim ? parseISO(lancamento.data_fim) : parseISO(lancamento.data_inicio),
            backgroundColor: '#ea580c',
            resource: { type: 'lancamento', data: lancamento }
          });
        }
      });

      // NPA Eventos
      npaEventos.forEach(npa => {
        if (npa.data_inicio) {
          events.push({
            id: `npa-${npa.id}`,
            title: npa.nome,
            start: parseISO(npa.data_inicio),
            end: npa.data_fim ? parseISO(npa.data_fim) : parseISO(npa.data_inicio),
            backgroundColor: '#9333ea',
            resource: { type: 'npa', data: npa }
          });
        }
      });

      // Eventos avulsos
      eventosCalendario.forEach(evento => {
        events.push({
          id: `evento-${evento.id}`,
          title: evento.titulo,
          start: parseISO(evento.data_inicio),
          end: evento.data_fim ? parseISO(evento.data_fim) : parseISO(evento.data_inicio),
          backgroundColor: evento.cor,
          resource: { type: 'evento', data: evento }
        });
      });

      return events;
    }, [tarefas, lancamentos, npaEventos, eventosCalendario]);

    const handleEventClick = (event: any) => {
      const { type, data } = event.resource;
      if (type === 'tarefa') {
        openTarefaDetail(data);
      } else {
        // Para outros tipos, mostrar modal com detalhes
        // Por enquanto, apenas toast
        toast({
          title: data.titulo || data.nome,
          description: data.descricao || `Tipo: ${type}`,
        });
      }
    };

    const handleCreateEvento = async () => {
      if (!eventoForm.titulo || !eventoForm.data_inicio) {
        toast({ variant: 'destructive', title: 'Erro', description: 'Título e data são obrigatórios' });
        return;
      }

      try {
        const { data, error } = await supabase.from('eventos_calendario').insert({
          titulo: eventoForm.titulo,
          descricao: eventoForm.descricao,
          data_inicio: eventoForm.data_inicio,
          data_fim: eventoForm.data_fim || eventoForm.data_inicio,
          cor: eventoForm.cor,
          created_by: user?.id
        });

        if (error) throw error;

        toast({ title: 'Sucesso', description: 'Evento criado com sucesso' });
        setShowCreateEvento(false);
        setEventoForm({ titulo: '', descricao: '', data_inicio: '', data_fim: '', cor: '#3b82f6' });
        loadData();
      } catch (error) {
        console.error('Erro ao criar evento:', error);
        toast({ variant: 'destructive', title: 'Erro', description: 'Falha ao criar evento' });
      }
    };

    return (
      <div className="space-y-4">
        <div className="flex justify-between items-center">
          <div className="flex gap-4 text-sm">
            <div className="flex items-center gap-2">
              <div className="w-3 h-3 bg-red-500 rounded"></div>
              <span>Tarefas</span>
            </div>
            <div className="flex items-center gap-2">
              <div className="w-3 h-3 bg-orange-500 rounded"></div>
              <span>Lançamentos</span>
            </div>
            <div className="flex items-center gap-2">
              <div className="w-3 h-3 bg-purple-500 rounded"></div>
              <span>NPA</span>
            </div>
            <div className="flex items-center gap-2">
              <div className="w-3 h-3 bg-blue-500 rounded"></div>
              <span>Eventos</span>
            </div>
          </div>
          <Button onClick={() => setShowCreateEvento(true)}>
            <Plus className="h-4 w-4 mr-2" />
            Evento
          </Button>
        </div>

        <div className="h-[600px]">
          <BigCalendar
            localizer={localizer}
            events={geralEvents}
            startAccessor="start"
            endAccessor="end"
            style={{ height: '100%' }}
            views={[Views.MONTH, Views.WEEK, Views.DAY]}
            defaultView={Views.MONTH}
            onSelectEvent={handleEventClick}
            onSelectSlot={(slotInfo) => {
              setEventoForm({
                ...eventoForm,
                data_inicio: format(slotInfo.start, "yyyy-MM-dd'T'HH:mm"),
                data_fim: format(slotInfo.end, "yyyy-MM-dd'T'HH:mm")
              });
              setShowCreateEvento(true);
            }}
            selectable
            messages={{
              next: 'Próximo',
              previous: 'Anterior',
              today: 'Hoje',
              month: 'Mês',
              week: 'Semana',
              day: 'Dia',
              agenda: 'Agenda',
              date: 'Data',
              time: 'Hora',
              event: 'Evento',
              noEventsInRange: 'Nenhum evento neste período.',
              showMore: (total) => `+ Ver mais ${total}`,
            }}
            culture="pt-BR"
            components={{
              toolbar: CustomToolbar,
              event: CustomEvent,
              dateCellWrapper: CustomDateCellWrapper,
              week: {
                header: CustomWeekHeader,
              },
            }}
          />
        </div>

        {/* Modal Criar Evento */}
        <Dialog open={showCreateEvento} onOpenChange={setShowCreateEvento}>
          <DialogContent>
            <DialogHeader>
              <DialogTitle>Novo Evento</DialogTitle>
            </DialogHeader>
            <div className="space-y-4">
              <div>
                <label className="text-sm font-medium">Título *</label>
                <Input
                  value={eventoForm.titulo}
                  onChange={(e) => setEventoForm({ ...eventoForm, titulo: e.target.value })}
                  placeholder="Título do evento"
                />
              </div>
              <div>
                <label className="text-sm font-medium">Descrição</label>
                <Textarea
                  value={eventoForm.descricao}
                  onChange={(e) => setEventoForm({ ...eventoForm, descricao: e.target.value })}
                  placeholder="Descrição do evento"
                  rows={3}
                />
              </div>
              <div className="grid grid-cols-2 gap-3">
                <div>
                  <label className="text-sm font-medium">Data Início *</label>
                  <Input
                    type="datetime-local"
                    value={eventoForm.data_inicio}
                    onChange={(e) => setEventoForm({ ...eventoForm, data_inicio: e.target.value })}
                  />
                </div>
                <div>
                  <label className="text-sm font-medium">Data Fim</label>
                  <Input
                    type="datetime-local"
                    value={eventoForm.data_fim}
                    onChange={(e) => setEventoForm({ ...eventoForm, data_fim: e.target.value })}
                  />
                </div>
              </div>
              <div>
                <label className="text-sm font-medium">Cor</label>
                <Input
                  type="color"
                  value={eventoForm.cor}
                  onChange={(e) => setEventoForm({ ...eventoForm, cor: e.target.value })}
                  className="w-20 h-10"
                />
              </div>
            </div>
            <DialogFooter>
              <Button variant="outline" onClick={() => setShowCreateEvento(false)}>
                Cancelar
              </Button>
              <Button onClick={handleCreateEvento}>
                Criar Evento
              </Button>
            </DialogFooter>
          </DialogContent>
        </Dialog>
      </div>
    );
  }

  function CalendarioConteudoView() {
    const [showCreateConteudo, setShowCreateConteudo] = useState(false);
    const [selectedConteudo, setSelectedConteudo] = useState<ConteudoCalendario | null>(null);
    const [conteudoForm, setConteudoForm] = useState({
      titulo: '',
      plataforma: 'instagram' as 'instagram' | 'youtube' | 'tiktok' | 'linkedin',
      formato: 'feed' as 'reels' | 'feed' | 'stories' | 'carrossel' | 'video' | 'short',
      responsavel: '',
      status: 'ideia' as 'ideia' | 'roteiro' | 'gravando' | 'editando' | 'agendado' | 'publicado',
      data_publicacao: '',
      legenda: '',
      link: '',
      observacoes: ''
    });

    const filteredConteudo = useMemo(() => {
      if (plataformaFilter === 'todos') return conteudoCalendario;
      return conteudoCalendario.filter(c => c.plataforma === plataformaFilter);
    }, [conteudoCalendario, plataformaFilter]);

    const conteudoEvents = useMemo(() => {
      return filteredConteudo.map(conteudo => ({
        id: `conteudo-${conteudo.id}`,
        title: conteudo.titulo,
        start: parseISO(conteudo.data_publicacao),
        end: parseISO(conteudo.data_publicacao),
        backgroundColor: getPlataformaColor(conteudo.plataforma),
        resource: conteudo
      }));
    }, [filteredConteudo]);

    const getPlataformaColor = (plataforma: string) => {
      switch (plataforma) {
        case 'instagram': return '#E1306C';
        case 'youtube': return '#FF0000';
        case 'tiktok': return '#000000';
        case 'linkedin': return '#0077B5';
        default: return '#6b7280';
      }
    };

    const getPlataformaIcon = (plataforma: string) => {
      switch (plataforma) {
        case 'instagram': return <Instagram className="h-3 w-3" />;
        case 'youtube': return <Youtube className="h-3 w-3" />;
        case 'tiktok': return <Music className="h-3 w-3" />;
        case 'linkedin': return <Linkedin className="h-3 w-3" />;
        default: return null;
      }
    };

    const handleEventClick = (event: any) => {
      setSelectedConteudo(event.resource);
    };

    const handleCreateConteudo = async () => {
      if (!conteudoForm.titulo || !conteudoForm.data_publicacao) {
        toast({ variant: 'destructive', title: 'Erro', description: 'Título e data são obrigatórios' });
        return;
      }

      try {
        const { data, error } = await supabase.from('conteudo_calendario').insert({
          ...conteudoForm,
          created_at: new Date().toISOString()
        });

        if (error) throw error;

        toast({ title: 'Sucesso', description: 'Conteúdo criado com sucesso' });
        setShowCreateConteudo(false);
        resetConteudoForm();
        loadData();
      } catch (error) {
        console.error('Erro ao criar conteúdo:', error);
        toast({ variant: 'destructive', title: 'Erro', description: 'Falha ao criar conteúdo' });
      }
    };

    const handleUpdateConteudo = async () => {
      if (!selectedConteudo) return;

      try {
        const { error } = await supabase
          .from('conteudo_calendario')
          .update(conteudoForm)
          .eq('id', selectedConteudo.id);

        if (error) throw error;

        toast({ title: 'Sucesso', description: 'Conteúdo atualizado com sucesso' });
        setSelectedConteudo(null);
        resetConteudoForm();
        loadData();
      } catch (error) {
        console.error('Erro ao atualizar conteúdo:', error);
        toast({ variant: 'destructive', title: 'Erro', description: 'Falha ao atualizar conteúdo' });
      }
    };

    const handleDeleteConteudo = async () => {
      if (!selectedConteudo) return;

      if (!confirm('Tem certeza que deseja excluir este conteúdo?')) return;

      try {
        const { error } = await supabase
          .from('conteudo_calendario')
          .delete()
          .eq('id', selectedConteudo.id);

        if (error) throw error;

        toast({ title: 'Sucesso', description: 'Conteúdo excluído com sucesso' });
        setSelectedConteudo(null);
        loadData();
      } catch (error) {
        console.error('Erro ao excluir conteúdo:', error);
        toast({ variant: 'destructive', title: 'Erro', description: 'Falha ao excluir conteúdo' });
      }
    };

    const resetConteudoForm = () => {
      setConteudoForm({
        titulo: '',
        plataforma: 'instagram',
        formato: 'feed',
        responsavel: '',
        status: 'ideia',
        data_publicacao: '',
        legenda: '',
        link: '',
        observacoes: ''
      });
    };

    const openEditModal = (conteudo: ConteudoCalendario) => {
      setSelectedConteudo(conteudo);
      setConteudoForm({
        titulo: conteudo.titulo,
        plataforma: conteudo.plataforma,
        formato: conteudo.formato,
        responsavel: conteudo.responsavel,
        status: conteudo.status,
        data_publicacao: conteudo.data_publicacao.split('T')[0],
        legenda: conteudo.legenda || '',
        link: conteudo.link || '',
        observacoes: conteudo.observacoes || ''
      });
    };

    return (
      <div className="space-y-4">
        <div className="flex justify-between items-center">
          <div className="flex gap-2">
            {(['todos', 'instagram', 'youtube', 'tiktok', 'linkedin'] as const).map(plataforma => (
              <Button
                key={plataforma}
                variant={plataformaFilter === plataforma ? 'default' : 'outline'}
                size="sm"
                onClick={() => setPlataformaFilter(plataforma)}
                className="capitalize"
              >
                {plataforma === 'todos' ? 'Todos' : plataforma}
              </Button>
            ))}
          </div>
          <Button onClick={() => setShowCreateConteudo(true)}>
            <Plus className="h-4 w-4 mr-2" />
            Conteúdo
          </Button>
        </div>

        <div className="h-[600px]">
          <BigCalendar
            localizer={localizer}
            events={conteudoEvents}
            startAccessor="start"
            endAccessor="end"
            style={{ height: '100%' }}
            views={[Views.MONTH, Views.WEEK, Views.DAY]}
            defaultView={Views.MONTH}
            onSelectEvent={handleEventClick}
            onSelectSlot={(slotInfo) => {
              setConteudoForm({
                ...conteudoForm,
                data_publicacao: format(slotInfo.start, "yyyy-MM-dd")
              });
              setShowCreateConteudo(true);
            }}
            selectable
            messages={{
              next: 'Próximo',
              previous: 'Anterior',
              today: 'Hoje',
              month: 'Mês',
              week: 'Semana',
              day: 'Dia',
              agenda: 'Agenda',
              date: 'Data',
              time: 'Hora',
              event: 'Evento',
              noEventsInRange: 'Nenhum conteúdo neste período.',
              showMore: (total) => `+ Ver mais ${total}`,
            }}
            culture="pt-BR"
            components={{
              toolbar: CustomToolbar,
              event: ({ event }: any) => (
                <div className="flex items-center gap-1 text-xs font-medium px-1">
                  {getPlataformaIcon(event.resource.plataforma)}
                  <span className="truncate">{event.title}</span>
                  <Badge variant="secondary" className="text-xs ml-1">
                    {event.resource.status}
                  </Badge>
                </div>
              ),
              dateCellWrapper: CustomDateCellWrapper,
              week: {
                header: CustomWeekHeader,
              },
            }}
          />
        </div>

        {/* Modal Criar/Editar Conteúdo */}
        <Dialog open={showCreateConteudo || !!selectedConteudo} onOpenChange={(open) => {
          if (!open) {
            setShowCreateConteudo(false);
            setSelectedConteudo(null);
            resetConteudoForm();
          }
        }}>
          <DialogContent className="max-w-2xl">
            <DialogHeader>
              <DialogTitle>{selectedConteudo ? 'Editar Conteúdo' : 'Novo Conteúdo'}</DialogTitle>
            </DialogHeader>
            <div className="space-y-4">
              <div>
                <label className="text-sm font-medium">Título *</label>
                <Input
                  value={conteudoForm.titulo}
                  onChange={(e) => setConteudoForm({ ...conteudoForm, titulo: e.target.value })}
                  placeholder="Título do conteúdo"
                />
              </div>
              <div className="grid grid-cols-2 gap-3">
                <div>
                  <label className="text-sm font-medium">Plataforma</label>
                  <Select
                    value={conteudoForm.plataforma}
                    onValueChange={(value: any) => setConteudoForm({ ...conteudoForm, plataforma: value })}
                  >
                    <SelectTrigger>
                      <SelectValue />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="instagram">Instagram</SelectItem>
                      <SelectItem value="youtube">YouTube</SelectItem>
                      <SelectItem value="tiktok">TikTok</SelectItem>
                      <SelectItem value="linkedin">LinkedIn</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
                <div>
                  <label className="text-sm font-medium">Formato</label>
                  <Select
                    value={conteudoForm.formato}
                    onValueChange={(value: any) => setConteudoForm({ ...conteudoForm, formato: value })}
                  >
                    <SelectTrigger>
                      <SelectValue />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="reels">Reels</SelectItem>
                      <SelectItem value="feed">Feed</SelectItem>
                      <SelectItem value="stories">Stories</SelectItem>
                      <SelectItem value="carrossel">Carrossel</SelectItem>
                      <SelectItem value="video">Vídeo</SelectItem>
                      <SelectItem value="short">Short</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
              </div>
              <div className="grid grid-cols-2 gap-3">
                <div>
                  <label className="text-sm font-medium">Responsável</label>
                  <Select
                    value={conteudoForm.responsavel}
                    onValueChange={(value) => setConteudoForm({ ...conteudoForm, responsavel: value })}
                  >
                    <SelectTrigger>
                      <SelectValue placeholder="Selecione..." />
                    </SelectTrigger>
                    <SelectContent>
                      {users.filter(u => u.ativo).map(user => (
                        <SelectItem key={user.id} value={user.id}>
                          {user.nome}
                        </SelectItem>
                      ))}
                    </SelectContent>
                  </Select>
                </div>
                <div>
                  <label className="text-sm font-medium">Status</label>
                  <Select
                    value={conteudoForm.status}
                    onValueChange={(value: any) => setConteudoForm({ ...conteudoForm, status: value })}
                  >
                    <SelectTrigger>
                      <SelectValue />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="ideia">Ideia</SelectItem>
                      <SelectItem value="roteiro">Roteiro</SelectItem>
                      <SelectItem value="gravando">Gravando</SelectItem>
                      <SelectItem value="editando">Editando</SelectItem>
                      <SelectItem value="agendado">Agendado</SelectItem>
                      <SelectItem value="publicado">Publicado</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
              </div>
              <div>
                <label className="text-sm font-medium">Data de Publicação *</label>
                <Input
                  type="date"
                  value={conteudoForm.data_publicacao}
                  onChange={(e) => setConteudoForm({ ...conteudoForm, data_publicacao: e.target.value })}
                />
              </div>
              <div>
                <label className="text-sm font-medium">Legenda</label>
                <Textarea
                  value={conteudoForm.legenda}
                  onChange={(e) => setConteudoForm({ ...conteudoForm, legenda: e.target.value })}
                  placeholder="Legenda do post"
                  rows={3}
                />
              </div>
              <div>
                <label className="text-sm font-medium">Link</label>
                <Input
                  value={conteudoForm.link}
                  onChange={(e) => setConteudoForm({ ...conteudoForm, link: e.target.value })}
                  placeholder="Link do conteúdo"
                />
              </div>
              <div>
                <label className="text-sm font-medium">Observações</label>
                <Textarea
                  value={conteudoForm.observacoes}
                  onChange={(e) => setConteudoForm({ ...conteudoForm, observacoes: e.target.value })}
                  placeholder="Observações adicionais"
                  rows={2}
                />
              </div>
            </div>
            <DialogFooter>
              {selectedConteudo && (
                <Button variant="destructive" onClick={handleDeleteConteudo} className="mr-auto">
                  <Trash2 className="h-4 w-4 mr-2" />
                  Excluir
                </Button>
              )}
              <Button variant="outline" onClick={() => {
                setShowCreateConteudo(false);
                setSelectedConteudo(null);
                resetConteudoForm();
              }}>
                Cancelar
              </Button>
              <Button onClick={selectedConteudo ? handleUpdateConteudo : handleCreateConteudo}>
                {selectedConteudo ? 'Atualizar' : 'Criar'} Conteúdo
              </Button>
            </DialogFooter>
          </DialogContent>
        </Dialog>
      </div>
    );
  }

  function TarefaCard({ tarefa }: { tarefa: Tarefa }) {
    return (
      <Card className="p-4 hover:shadow-md transition-shadow">
        <div className="flex items-start justify-between mb-3">
          <div className="flex-1">
            <h4 className="font-medium text-foreground mb-1">{tarefa.titulo}</h4>
            {tarefa.descricao && (
              <p className="text-sm text-muted-foreground mb-2 line-clamp-2">
                {tarefa.descricao}
              </p>
            )}
          </div>
          <div className="flex gap-1">
            <Button
              variant="ghost"
              size="sm"
              onClick={() => openTarefaDetail(tarefa)}
            >
              <Eye className="h-4 w-4" />
            </Button>
            <Button
              variant="ghost"
              size="sm"
              onClick={() => confirmDelete('tarefa', tarefa.id, tarefa.titulo)}
              className="text-destructive hover:text-destructive"
            >
              <Trash2 className="h-4 w-4" />
            </Button>
          </div>
        </div>

        <div className="flex flex-wrap gap-2 items-center">
          <Badge className={getStatusColor(tarefa.status)}>
            {tarefa.status.replace('_', ' ')}
          </Badge>
          <Badge className={getPriorityColor(tarefa.prioridade)}>
            {tarefa.prioridade}
          </Badge>
          {tarefa.tipo === 'sequencial' && (
            <Badge variant="outline">🔗 Sequencial</Badge>
          )}
          {(tarefa.responsaveis ?? []).map(respId => {
            const user = users.find(u => u.id === respId);
            return user ? (
              <Badge key={respId} variant="secondary" className="text-xs">
                {user.nome.split(' ')[0]}
              </Badge>
            ) : null;
          })}
          {tarefa.prazo && (
            <span className="text-xs text-muted-foreground">
              📅 {format(parseISO(tarefa.prazo), 'dd/MM')}
            </span>
          )}
        </div>
      </Card>
    );
  }

  function TarefaKanbanCard({ tarefa }: { tarefa: Tarefa }) {
    return (
      <Card className="p-3 cursor-pointer hover:shadow-md transition-shadow">
        <h4 className="font-medium text-sm mb-2">{tarefa.titulo}</h4>
        <div className="flex flex-wrap gap-1">
          <Badge className={cn('text-xs', getPriorityColor(tarefa.prioridade))}>
            {tarefa.prioridade}
          </Badge>
          {(tarefa.responsaveis ?? []).slice(0, 2).map(respId => {
            const user = users.find(u => u.id === respId);
            return user ? (
              <Badge key={respId} variant="outline" className="text-xs">
                {user.nome.split(' ')[0]}
              </Badge>
            ) : null;
          })}
        </div>
      </Card>
    );
  }

  function ModalCreateTarefa() {
    return (
      <Dialog open={showCreateTarefa} onOpenChange={setShowCreateTarefa}>
        <DialogContent className="max-w-2xl">
          <DialogHeader>
            <DialogTitle>Nova Tarefa</DialogTitle>
            <DialogDescription>
              Crie uma nova tarefa para a equipe
            </DialogDescription>
          </DialogHeader>

          <div className="space-y-4">
            <div>
              <label className="text-sm font-medium">Título *</label>
              <Input
                value={tarefaForm.titulo}
                onChange={(e) => setTarefaForm({ ...tarefaForm, titulo: e.target.value })}
                placeholder="Título da tarefa"
                className="mt-1"
              />
            </div>

            <div>
              <label className="text-sm font-medium">Descrição</label>
              <Textarea
                value={tarefaForm.descricao}
                onChange={(e) => setTarefaForm({ ...tarefaForm, descricao: e.target.value })}
                placeholder="Descrição detalhada da tarefa"
                className="mt-1"
                rows={3}
              />
            </div>

            <div className="grid grid-cols-2 gap-3">
              <div>
                <label className="text-sm font-medium">Tipo</label>
                <Select
                  value={tarefaForm.tipo}
                  onValueChange={(value: any) => setTarefaForm({ ...tarefaForm, tipo: value })}
                >
                  <SelectTrigger className="mt-1">
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="unitaria">Unitária</SelectItem>
                    <SelectItem value="sequencial">Sequencial</SelectItem>
                  </SelectContent>
                </Select>
              </div>

              <div>
                <label className="text-sm font-medium">Prioridade</label>
                <Select
                  value={tarefaForm.prioridade}
                  onValueChange={(value: any) => setTarefaForm({ ...tarefaForm, prioridade: value })}
                >
                  <SelectTrigger className="mt-1">
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="baixa">🟢 Baixa</SelectItem>
                    <SelectItem value="media">🟡 Média</SelectItem>
                    <SelectItem value="alta">🟠 Alta</SelectItem>
                    <SelectItem value="urgente">🔴 Urgente</SelectItem>
                  </SelectContent>
                </Select>
              </div>
            </div>

            <div>
              <label className="text-sm font-medium">Responsáveis</label>
              <div className="mt-1 space-y-2">
                {users.filter(u => u.ativo).map(user => (
                  <div key={user.id} className="flex items-center space-x-2">
                    <Checkbox
                      id={user.id}
                      checked={tarefaForm.responsaveis.includes(user.id)}
                      onCheckedChange={(checked) => {
                        if (checked) {
                          setTarefaForm({
                            ...tarefaForm,
                            responsaveis: [...tarefaForm.responsaveis, user.id]
                          });
                        } else {
                          setTarefaForm({
                            ...tarefaForm,
                            responsaveis: tarefaForm.responsaveis.filter(id => id !== user.id)
                          });
                        }
                      }}
                    />
                    <label htmlFor={user.id} className="text-sm">
                      {user.nome}
                    </label>
                  </div>
                ))}
              </div>
            </div>

            <div className="grid grid-cols-2 gap-3">
              <div>
                <label className="text-sm font-medium">Data de Início</label>
                <Input
                  type="date"
                  value={tarefaForm.data_inicio}
                  onChange={(e) => setTarefaForm({ ...tarefaForm, data_inicio: e.target.value })}
                  className="mt-1"
                />
              </div>
              <div>
                <label className="text-sm font-medium">Prazo</label>
                <Input
                  type="date"
                  value={tarefaForm.prazo}
                  onChange={(e) => setTarefaForm({ ...tarefaForm, prazo: e.target.value })}
                  className="mt-1"
                />
              </div>
            </div>
          </div>

          <DialogFooter>
            <Button variant="outline" onClick={() => setShowCreateTarefa(false)}>
              Cancelar
            </Button>
            <Button onClick={createTarefa} className="bg-red-600 hover:bg-red-700">
              Criar Tarefa
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    );
  }

  function ModalTarefaDetail() {
    if (!selectedTarefa) return null;

    return (
      <Dialog open={showTarefaDetail} onOpenChange={setShowTarefaDetail}>
        <DialogContent className="max-w-4xl max-h-[80vh] overflow-y-auto">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2">
              {selectedTarefa.titulo}
              {selectedTarefa.tipo === 'sequencial' && <Badge variant="outline">🔗 Sequencial</Badge>}
            </DialogTitle>
          </DialogHeader>

          <div className="space-y-6">
            {/* Status e prioridade */}
            <div className="flex gap-2">
              <Badge className={getStatusColor(selectedTarefa.status)}>
                {selectedTarefa.status.replace('_', ' ')}
              </Badge>
              <Badge className={getPriorityColor(selectedTarefa.prioridade)}>
                {selectedTarefa.prioridade}
              </Badge>
            </div>

            {/* Descrição */}
            {selectedTarefa.descricao && (
              <div>
                <h4 className="font-medium mb-2">Descrição</h4>
                <p className="text-sm text-muted-foreground">{selectedTarefa.descricao}</p>
              </div>
            )}

            {/* Responsáveis */}
            <div>
              <h4 className="font-medium mb-2">Responsáveis</h4>
              <div className="flex flex-wrap gap-2">
                {(selectedTarefa.responsaveis ?? []).map(respId => {
                  const user = users.find(u => u.id === respId);
                  return user ? (
                    <Badge key={respId} variant="secondary">
                      {user.nome}
                    </Badge>
                  ) : null;
                })}
              </div>
            </div>

            {/* Datas */}
            <div className="grid grid-cols-2 gap-4">
              {selectedTarefa.data_inicio && (
                <div>
                  <h4 className="font-medium mb-1">Data de Início</h4>
                  <p className="text-sm text-muted-foreground">
                    {format(parseISO(selectedTarefa.data_inicio), 'dd/MM/yyyy', { locale: ptBR })}
                  </p>
                </div>
              )}
              {selectedTarefa.prazo && (
                <div>
                  <h4 className="font-medium mb-1">Prazo</h4>
                  <p className="text-sm text-muted-foreground">
                    {format(parseISO(selectedTarefa.prazo), 'dd/MM/yyyy', { locale: ptBR })}
                  </p>
                </div>
              )}
            </div>

            {/* Tags */}
            {((selectedTarefa.tags ?? []).length > 0) && (
              <div>
                <h4 className="font-medium mb-2">Tags</h4>
                <div className="flex flex-wrap gap-2">
                  {(selectedTarefa.tags ?? []).map((tag, index) => (
                    <Badge key={index} variant="outline">
                      {tag}
                    </Badge>
                  ))}
                </div>
              </div>
            )}

            {/* Checklist */}
            <div>
              <h4 className="font-medium mb-2">Checklist</h4>
              <p className="text-sm text-muted-foreground">Em desenvolvimento</p>
            </div>

            {/* Comentários */}
            <div>
              <h4 className="font-medium mb-2">Comentários</h4>
              <p className="text-sm text-muted-foreground">Em desenvolvimento</p>
            </div>
          </div>

          <DialogFooter>
            <Button variant="outline" onClick={() => setShowTarefaDetail(false)}>
              Fechar
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    );
  }

  function ModalCreateEvento() {
    return (
      <Dialog open={showCreateEvento} onOpenChange={setShowCreateEvento}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Novo Evento</DialogTitle>
          </DialogHeader>
          <p className="text-muted-foreground">Em desenvolvimento</p>
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowCreateEvento(false)}>
              Fechar
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    );
  }

  function ModalCreateConteudo() {
    return (
      <Dialog open={showCreateConteudo} onOpenChange={setShowCreateConteudo}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Novo Conteúdo</DialogTitle>
          </DialogHeader>
          <p className="text-muted-foreground">Em desenvolvimento</p>
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowCreateConteudo(false)}>
              Fechar
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    );
  }

  function ModalDeleteConfirm() {
    if (!itemToDelete) return null;

    return (
      <Dialog open={showDeleteConfirm} onOpenChange={setShowDeleteConfirm}>
        <DialogContent className="max-w-md">
          <DialogHeader>
            <DialogTitle className="text-destructive">Confirmar Exclusão</DialogTitle>
            <DialogDescription>
              Tem certeza que deseja excluir <strong>{itemToDelete.name}</strong>?<br />
              Esta ação não pode ser desfeita.
            </DialogDescription>
          </DialogHeader>
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowDeleteConfirm(false)}>
              Cancelar
            </Button>
            <Button
              variant="destructive"
              onClick={deleteTarefa}
              className="bg-red-600 hover:bg-red-700"
            >
              Confirmar Exclusão
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    );
  }
}
